# Config Firebase (demo cross-device). Copier en .env et renseigner depuis
# `firebase apps:sdkconfig web`. Sans ces variables, l'app tourne en mode local
# (localStorage, sync meme appareil seulement).
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_SENDER_ID=
VITE_FB_APP_ID=
